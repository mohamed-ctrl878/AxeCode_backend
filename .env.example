# 🚀 AxeCode Backend - Environment Configuration Model

# ── Server Configuration ──
HOST=0.0.0.0
PORT=1338

# ── Security Secrets ──
# Use 'openssl rand -base64 32' to generate secure random strings
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=generate_a_random_salt
ADMIN_JWT_SECRET=generate_a_random_secret
TRANSFER_TOKEN_SALT=generate_a_random_salt
JWT_SECRET=generate_a_random_jwt_secret

# ── Database Configuration ──
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=axecode_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password
DATABASE_SSL=false
DATABASE_FILENAME= # Used only if DATABASE_CLIENT=sqlite

# ── Email Strategy (GMAIL) ──
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-google-app-password

# ── GitHub OAuth ──
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
COOKIE_DOMAIN=localhost

# ── reCAPTCHA Configuration ──
# Get these keys from Google reCAPTCHA Console: https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your_public_site_key
RECAPTCHA_SECRET_KEY=your_private_secret_key
RECAPTCHA_REQUIRED=true
RECAPTCHA_MIN_SCORE=0.5

# ── MediaMTX (Live Streaming) ──
MEDIAMTX_HLS_URL=http://localhost:8888
MEDIAMTX_RTMP_URL=rtmp://localhost:1935

# ── Judge0 (Code Execution) ──
JUDGE0_API_URL=http://localhost:2358

# ── Web Push Notifications (VAPID) ──
# Generate these using 'npx web-push generate-vapid-keys'
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.com
